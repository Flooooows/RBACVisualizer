generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ImportSourceType {
  YAML
  JSON
}

enum SnapshotStatus {
  RECEIVED
  PARSING
  VALIDATING
  NORMALIZING
  COMPLETED
  COMPLETED_WITH_WARNINGS
  FAILED
}

enum SubjectKind {
  USER
  GROUP
  SERVICE_ACCOUNT
}

enum SubjectOrigin {
  BINDING
  MANIFEST
  BOTH
}

enum RoleRefKind {
  ROLE
  CLUSTER_ROLE
}

enum FindingType {
  CLUSTER_ADMIN_USAGE
  WILDCARD_PERMISSION
  SENSITIVE_RESOURCE_FULL_ACCESS
  REDUNDANT_BINDING_PATH
  EMPTY_ROLE
  UNUSED_ROLE
  BROKEN_ROLE_REF
  EXCESSIVE_PRIVILEGE
}

enum FindingSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
  BILLING
}

enum WorkspacePlanTier {
  FREE
  TEAM
  ENTERPRISE
}

enum WorkspaceStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum ClusterProvider {
  KUBERNETES
  OPENSHIFT
}

enum ClusterConnectionStatus {
  ACTIVE
  DISABLED
  ERROR
}

enum ImportTrigger {
  MANUAL
  SCHEDULED
  API
}

enum ImportRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

enum BillingSubscriptionStatus {
  NONE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

model Account {
  id                        String               @id @default(cuid())
  email                     String               @unique
  displayName               String?
  avatarUrl                 String?
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  memberships               WorkspaceMembership[]
  ownedWorkspaces           Workspace[]          @relation("WorkspaceOwner")
  createdClusterConnections ClusterConnection[]  @relation("ClusterConnectionCreatedBy")
  triggeredImportRuns       ImportRun[]          @relation("ImportRunTriggeredBy")
}

model Workspace {
  id             String                @id @default(cuid())
  slug           String                @unique
  name           String
  ownerAccountId String
  planTier       WorkspacePlanTier     @default(FREE)
  status         WorkspaceStatus       @default(ACTIVE)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  owner          Account               @relation("WorkspaceOwner", fields: [ownerAccountId], references: [id], onDelete: Restrict)
  memberships    WorkspaceMembership[]
  projects       Project[]
  billing        WorkspaceBilling?
  usageMonthly   WorkspaceUsageMonthly[]

  @@index([ownerAccountId])
}

model WorkspaceMembership {
  id                 String        @id @default(cuid())
  workspaceId        String
  accountId          String
  role               WorkspaceRole
  invitedByAccountId String?
  joinedAt           DateTime      @default(now())
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  workspace          Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account            Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, accountId])
  @@index([accountId])
  @@index([workspaceId, role])
}

model Project {
  id                 String              @id @default(cuid())
  workspaceId        String
  slug               String
  name               String
  description        String?
  isArchived         Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clusterConnections ClusterConnection[]
  importRuns         ImportRun[]
  snapshots          ImportSnapshot[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, isArchived])
}

model ClusterConnection {
  id                 String                  @id @default(cuid())
  projectId          String
  name               String
  provider           ClusterProvider
  apiServerHost      String?
  kubeconfigPath     String?
  contextName        String?
  authRef            String?
  status             ClusterConnectionStatus @default(ACTIVE)
  createdByAccountId String?
  lastValidatedAt    DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  project            Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy          Account?                @relation("ClusterConnectionCreatedBy", fields: [createdByAccountId], references: [id], onDelete: SetNull)
  importRuns         ImportRun[]

  @@unique([projectId, name])
  @@index([projectId, status])
}

model ImportRun {
  id                   String          @id @default(cuid())
  projectId            String
  clusterConnectionId  String?
  triggeredByAccountId String?
  trigger              ImportTrigger
  status               ImportRunStatus @default(QUEUED)
  startedAt            DateTime        @default(now())
  finishedAt           DateTime?
  errorSummary         String?
  project              Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clusterConnection    ClusterConnection? @relation(fields: [clusterConnectionId], references: [id], onDelete: SetNull)
  triggeredBy          Account?        @relation("ImportRunTriggeredBy", fields: [triggeredByAccountId], references: [id], onDelete: SetNull)
  snapshot             ImportSnapshot? @relation("ImportRunSnapshot")

  @@index([projectId, startedAt])
  @@index([status, startedAt])
  @@index([clusterConnectionId])
}

model ImportSnapshot {
  id                  String               @id @default(cuid())
  sourceType          ImportSourceType
  sourceLabel         String?
  status              SnapshotStatus       @default(RECEIVED)
  importedAt          DateTime             @default(now())
  completedAt         DateTime?
  checksum            String?
  projectId           String?
  importRunId         String?              @unique
  rawManifests        RawManifest[]
  namespaces          Namespace[]
  subjects            Subject[]
  roles               Role[]
  clusterRoles        ClusterRole[]
  roleBindings        RoleBinding[]
  clusterRoleBindings ClusterRoleBinding[]
  findings            AnalysisFinding[]
  project             Project?             @relation(fields: [projectId], references: [id], onDelete: Restrict)
  importRun           ImportRun?           @relation("ImportRunSnapshot", fields: [importRunId], references: [id], onDelete: SetNull)

  @@index([importedAt])
  @@index([projectId, importedAt])
}

model WorkspaceBilling {
  id                 String                    @id @default(cuid())
  workspaceId        String                    @unique
  billingEmail       String?
  providerCustomerId String?                   @unique
  subscriptionStatus BillingSubscriptionStatus @default(NONE)
  updatedAt          DateTime                  @updatedAt
  workspace          Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model WorkspaceUsageMonthly {
  id                String    @id @default(cuid())
  workspaceId       String
  periodStart       DateTime
  importRunCount    Int       @default(0)
  snapshotCount     Int       @default(0)
  activeMemberCount Int       @default(0)
  updatedAt         DateTime  @updatedAt
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, periodStart])
  @@index([periodStart])
}

model RawManifest {
  id            String         @id @default(cuid())
  snapshotId    String
  apiVersion    String
  kind          String
  namespace     String?
  name          String
  uid           String?
  labels        Json?
  annotations   Json?
  documentOrder Int?
  manifest      Json
  createdAt     DateTime       @default(now())
  snapshot      ImportSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@unique([snapshotId, kind, namespace, name])
  @@index([snapshotId, kind])
  @@index([snapshotId, namespace])
}

model Namespace {
  id           String         @id @default(cuid())
  snapshotId   String
  name         String
  labels       Json?
  annotations  Json?
  snapshot     ImportSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  roles        Role[]
  roleBindings RoleBinding[]

  @@unique([snapshotId, name])
  @@index([snapshotId])
}

model Subject {
  id                       String                      @id @default(cuid())
  snapshotId               String
  kind                     SubjectKind
  name                     String
  namespace                String?
  origin                   SubjectOrigin               @default(BINDING)
  snapshot                 ImportSnapshot              @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  roleBindingSubjects      RoleBindingSubject[]
  clusterRoleBindingSubjects ClusterRoleBindingSubject[]
  findings                 AnalysisFinding[]

  @@unique([snapshotId, kind, name, namespace])
  @@index([snapshotId, kind, name])
  @@index([snapshotId, namespace])
}

model Role {
  id                   String          @id @default(cuid())
  snapshotId           String
  namespace            String
  name                 String
  labels               Json?
  annotations          Json?
  snapshot             ImportSnapshot  @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  namespaceRef         Namespace       @relation(fields: [snapshotId, namespace], references: [snapshotId, name], onDelete: Restrict)
  rules                RoleRule[]
  referencedByBindings RoleBinding[]   @relation("RoleBindingRoleRefRole")
  findings             AnalysisFinding[]

  @@unique([snapshotId, namespace, name])
  @@index([snapshotId, namespace])
}

model RoleRule {
  id              String   @id @default(cuid())
  roleId          String
  ruleOrder       Int
  apiGroups       String[] @default([])
  resources       String[] @default([])
  verbs           String[] @default([])
  resourceNames   String[] @default([])
  nonResourceURLs String[] @default([])
  role            Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, ruleOrder])
  @@index([roleId])
}

model ClusterRole {
  id                             String               @id @default(cuid())
  snapshotId                     String
  name                           String
  labels                         Json?
  annotations                    Json?
  aggregationRule                Json?
  snapshot                       ImportSnapshot       @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  rules                          ClusterRoleRule[]
  referencedByRoleBindings       RoleBinding[]        @relation("RoleBindingRoleRefClusterRole")
  referencedByClusterRoleBindings ClusterRoleBinding[] @relation("ClusterRoleBindingRoleRefClusterRole")
  findings                       AnalysisFinding[]

  @@unique([snapshotId, name])
  @@index([snapshotId])
}

model ClusterRoleRule {
  id              String      @id @default(cuid())
  clusterRoleId   String
  ruleOrder       Int
  apiGroups       String[]    @default([])
  resources       String[]    @default([])
  verbs           String[]    @default([])
  resourceNames   String[]    @default([])
  nonResourceURLs String[]    @default([])
  clusterRole     ClusterRole @relation(fields: [clusterRoleId], references: [id], onDelete: Cascade)

  @@unique([clusterRoleId, ruleOrder])
  @@index([clusterRoleId])
}

model RoleBinding {
  id                   String          @id @default(cuid())
  snapshotId           String
  namespace            String
  name                 String
  labels               Json?
  annotations          Json?
  roleRefKind          RoleRefKind
  roleRefApiGroup      String          @default("rbac.authorization.k8s.io")
  roleRefName          String
  roleRefRoleId        String?
  roleRefClusterRoleId String?
  isRoleRefResolved    Boolean         @default(false)
  snapshot             ImportSnapshot  @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  namespaceRef         Namespace       @relation(fields: [snapshotId, namespace], references: [snapshotId, name], onDelete: Restrict)
  roleRefRole          Role?           @relation("RoleBindingRoleRefRole", fields: [roleRefRoleId], references: [id], onDelete: SetNull)
  roleRefClusterRole   ClusterRole?    @relation("RoleBindingRoleRefClusterRole", fields: [roleRefClusterRoleId], references: [id], onDelete: SetNull)
  subjects             RoleBindingSubject[]
  findings             AnalysisFinding[]

  @@unique([snapshotId, namespace, name])
  @@index([snapshotId, namespace])
  @@index([snapshotId, roleRefKind, roleRefName])
  @@index([roleRefRoleId])
  @@index([roleRefClusterRoleId])
}

model RoleBindingSubject {
  id            String      @id @default(cuid())
  roleBindingId String
  subjectId     String
  roleBinding   RoleBinding @relation(fields: [roleBindingId], references: [id], onDelete: Cascade)
  subject       Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([roleBindingId, subjectId])
  @@index([subjectId])
}

model ClusterRoleBinding {
  id                   String                     @id @default(cuid())
  snapshotId           String
  name                 String
  labels               Json?
  annotations          Json?
  roleRefApiGroup      String                     @default("rbac.authorization.k8s.io")
  roleRefName          String
  roleRefClusterRoleId String?
  isRoleRefResolved    Boolean                    @default(false)
  snapshot             ImportSnapshot             @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  roleRefClusterRole   ClusterRole?               @relation("ClusterRoleBindingRoleRefClusterRole", fields: [roleRefClusterRoleId], references: [id], onDelete: SetNull)
  subjects             ClusterRoleBindingSubject[]
  findings             AnalysisFinding[]

  @@unique([snapshotId, name])
  @@index([snapshotId, roleRefName])
  @@index([roleRefClusterRoleId])
}

model ClusterRoleBindingSubject {
  id                   String             @id @default(cuid())
  clusterRoleBindingId String
  subjectId            String
  clusterRoleBinding   ClusterRoleBinding @relation(fields: [clusterRoleBindingId], references: [id], onDelete: Cascade)
  subject              Subject            @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([clusterRoleBindingId, subjectId])
  @@index([subjectId])
}

model AnalysisFinding {
  id                   String              @id @default(cuid())
  snapshotId           String
  type                 FindingType
  severity             FindingSeverity
  title                String
  details              Json?
  createdAt            DateTime            @default(now())
  subjectId            String?
  roleId               String?
  clusterRoleId        String?
  roleBindingId        String?
  clusterRoleBindingId String?
  snapshot             ImportSnapshot      @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  subject              Subject?            @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  role                 Role?               @relation(fields: [roleId], references: [id], onDelete: SetNull)
  clusterRole          ClusterRole?        @relation(fields: [clusterRoleId], references: [id], onDelete: SetNull)
  roleBinding          RoleBinding?        @relation(fields: [roleBindingId], references: [id], onDelete: SetNull)
  clusterRoleBinding   ClusterRoleBinding? @relation(fields: [clusterRoleBindingId], references: [id], onDelete: SetNull)

  @@index([snapshotId, type, severity])
  @@index([subjectId])
}
